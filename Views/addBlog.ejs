<%- include('partial/header') %>

<section class="add-blog-page">

  <div class="add-blog-card">

    <h1>✍️ Create a New Blog</h1>

    <p class="subtitle">
      Share your funny coding stories, jokes, and developer experiences 😎
    </p>

    <form action="/add-blog" method="POST" class="blog-form">
      <div class="form-group">
        <label>📌 Blog Title</label>
        <input
          type="text"
          name="title"
          placeholder="Enter blog title"
          required
        />
      </div>

      <div class="form-group">
        <label>👤 Author Name</label>
        <select name="author" required>
          <option value="">Select Author</option>
          <option value="admin">Admin</option>
          <option value="user">User</option>
        </select>
      </div>

      <div class="form-group">
        <label>📝 Blog Content</label>
        <textarea
          name="content"
          rows="6"
          placeholder="Write your funny blog content here..."
          required
        ></textarea>
      </div>

      <button type="submit" class="submit-btn">
        🚀 Publish Blog
      </button>
    </form>
  </div>
</section>

<%- include('partial/footer') %>