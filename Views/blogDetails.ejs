<%- include('partial/header') %>

<section class="details-page">
  <div class="details-card">
    <div class="details-top">
      <h1>
        <%= blog.title %>
      </h1>
      <% if(blog.author === 'admin') { %>
        <span class="admin-badge">Admin Blog</span>
      <% } else { %>
        <span class="user-badge">User Blog</span>
      <% } %>
    </div>

    <div class="details-content">
      <p>
        <%= blog.content %>
      </p>
    </div>
    <div class="author-section">
      <p>
        ✍️ <b>Author:</b> <%= blog.author %>
      </p>
    </div>
    <% if(blog.author === 'admin') { %>
      <div class="access-box admin-access">
        🔥 Admin Access: You can edit or delete this blog.
      </div>
    <% } else { %>
      <div class="access-box user-access">
        👀 Regular User Access: Read-only mode enabled.
      </div>
    <% } %>
    <div class="back-btn-container">
      <a href="/blogs" class="back-btn">
        ⬅ Back to All Blogs
      </a>
    </div>
  </div>
</section>

<%- include('partial/footer') %>